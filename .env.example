# Binance
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret
BINANCE_TESTNET=true

# Trading
TRADING_PAIR=BTC/EUR
# INITIAL_BALANCE_EUR is only used for P&L calculation reference (optional)
INITIAL_BALANCE_EUR=100
SELL_THRESHOLD_PCT=0.025
BUY_THRESHOLD_PCT=0.025
PRICE_POLL_INTERVAL_MS=30000

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_AUTH_TOKEN=change_this_to_a_random_string

# Logging
LOG_LEVEL=info
